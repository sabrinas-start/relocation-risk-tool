      "name": "Maps 2 - Adresse candidate"
    },
    {
      "parameters": {
        "jsCode": "// Récupération des données salarié depuis la boucle\nconst id_salarie = $('Boucle par salarié').item.json.id_salarie;\nconst score      = $('Boucle par salarié').item.json.score_competence;\n\nconst statusActuel   = $('Maps 1 - Adresse actuelle').item.json.rows[0].elements[0].status;\nconst statusCandidat = $('Maps 2 - Adresse candidate').item.json.rows[0].elements[0].status;\n\nif (statusActuel !== 'OK' || statusCandidat !== 'OK') {\n  return [{ json: {\n    id_salarie,\n    score_competence:  score,\n    trajet_actuel_min: null,\n    trajet_futur_min:  null,\n    delta_min:         null,\n    tolerance:         null,\n    risque_individuel: null,\n    erreur:            \"Adresse non reconnue par Maps API\"\n  }}];\n}\n\nconst trajet_actuel_min = $('Maps 1 - Adresse actuelle').item.json.rows[0].elements[0].duration.value / 60;\nconst trajet_futur_min  = $('Maps 2 - Adresse candidate').item.json.rows[0].elements[0].duration.value / 60;\n\nconst delta = trajet_futur_min - trajet_actuel_min;\n\n// f(delta) — inchangée\nlet f;\nif (delta <= 0)       { f = 0; }\nelse if (delta <= 30) { f = delta / 30; }\nelse                  { f = 1 + (delta - 30) / 10; }\n\n// tolérance(trajet_actuel) — NOUVEAU\nlet t;\nif (trajet_actuel_min <= 10)      { t = 0; }\nelse if (trajet_actuel_min <= 20) { t = 0.5; }\nelse if (trajet_actuel_min <= 30) { t = 1; }\nelse                              { t = 1 + (trajet_actuel_min - 30) / 15; }\n\nconst tolerance        = Math.round(t * 100) / 100;\nconst risque_individuel = Math.round((Math.pow(score, 1.5) + tolerance) * f * 100) / 100;\n\nreturn [{ json: {\n  id_salarie,\n  score_competence:  score,\n  trajet_actuel_min: Math.round(trajet_actuel_min),\n  trajet_futur_min:  Math.round(trajet_futur_min),\n  delta_min:         Math.round(delta),\n  tolerance,\n  risque_individuel\n}}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1152,
        96
      ],
