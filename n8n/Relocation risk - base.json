      "name": "Aggregate salaries"
    },
    {
      "parameters": {
        "jsCode": "const salaries = $input.first().json.salaries;\n\nconst valides = salaries.filter(s => s.risque_individuel !== null);\n\nconst somme = valides.reduce((sum, s) => sum + s.risque_individuel, 0);\n\nconst risque_global = valides.length > 0\n  ? Math.round((somme / salaries.length) * 100) / 100\n  : 0;\n\nreturn [{ json: { risque_global, salaries } }];"
      },
