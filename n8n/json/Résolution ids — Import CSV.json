    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst records = input.records || [];\nconst lignes = $('Execute Workflow Trigger').first().json.lignes || [];\n\nconst ids_existants = {};\nfor (const record of records) {\n  const id_salarie = record.fields?.id_salarie;\n  const record_id = record.id;\n  if (id_salarie && record_id && !ids_existants[id_salarie]) {\n    ids_existants[id_salarie] = record_id;\n  }\n}\n\nreturn lignes.map(ligne => ({\n  json: {\n    ...ligne,\n    score_competence: Number(ligne.score_competence),\n    ids_existants\n  }\n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
