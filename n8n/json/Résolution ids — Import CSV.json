{
  "name": "Résolution ids — Import CSV",
  "nodes": [
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst ids = input.ids || input.body?.ids || [];\n\nconst formule = ids.length === 1\n  ? `{id_salarie}=\"${ids[0]}\"`\n  : `OR(${ids.map(id => `{id_salarie}=\"${id}\"`).join(', ')})`;\n\nreturn [{ json: { formule_filtre: formule, ids } }];"
      },
