    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\nif (!input.statut && !input.lignes_valides) {\n  return [{ json: input }];\n}\n\nif (input.statut === 'erreur_structure') {\n  return [{ json: input }];\n}\n\nconst store = $getWorkflowStaticData('global');\nstore.inserts = 0;\nstore.updates = 0;\nstore.lignes_rejetees = input.lignes_rejetees || [];\n\nif (!input.lignes_valides || input.lignes_valides.length === 0) {\n  const rejetees = store.lignes_rejetees.map(l => ({\n    ligne_numero: l._ligne_numero,\n    id_salarie:   l.id_salarie || null,\n    erreurs:      l.erreurs || []\n  }));\n  return [{ json: {\n    statut:          'import_rejete',\n    message:         `Aucune ligne valide — ${rejetees.length} ligne(s) rejetée(s).`,\n    inserts:         0,\n    updates:         0,\n    rejetes:         rejetees.length,\n    lignes_rejetees: rejetees\n  }}];\n}\n\nreturn input.lignes_valides.map(ligne => ({ json: ligne }));"
      },
