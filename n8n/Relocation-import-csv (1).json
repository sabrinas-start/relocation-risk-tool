      "id": "919a5d5e-0dba-485f-9c64-b65ce7b40891",
      "name": "Webhook — Import CSV",
      "webhookId": "837f5906-70e2-4c8f-b682-ded3b788f354"
    },
    {
      "parameters": {
        "jsCode": "const csvString = $input.first().json.body?.csv;\n\nif (!csvString || csvString.trim() === '') {\n  return [{ json: { statut: 'erreur_structure', erreur_structure: 'CSV vide ou absent' } }];\n}\n\nfunction parseCSVLine(line) {\n  const result = [];\n  let current = '';\n  let inQuotes = false;\n  for (let i = 0; i < line.length; i++) {\n    const char = line[i];\n    if (char === '\"') {\n      inQuotes = !inQuotes;\n    } else if (char === ',' && !inQuotes) {\n      result.push(current.trim());\n      current = '';\n    } else {\n      current += char;\n    }\n  }\n  result.push(current.trim());\n  return result;\n}\n\nconst lignes = csvString.trim().split('\\n').map(l => l.trim()).filter(l => l !== '');\n\nif (lignes.length < 2) {\n  return [{ json: { statut: 'erreur_structure', erreur_structure: 'CSV sans données (header seul ou vide)' } }];\n}\n\nconst COLONNES_ATTENDUES = ['id_salarie', 'adresse_domicile', 'mode_transport', 'score_competence'];\n\nconst colonnesRecues = parseCSVLine(lignes[0]).map(c => c.replace(/\"/g, ''));\n\n// Cas 1 : correspondance exacte → structure valide\nif (JSON.stringify(colonnesRecues) === JSON.stringify(COLONNES_ATTENDUES)) {\n  const lignes_valides = [];\n  const lignes_rejetees = [];\n\n  for (let i = 1; i < lignes.length; i++) {\n    const valeurs = parseCSVLine(lignes[i]);\n    const ligne = {};\n    COLONNES_ATTENDUES.forEach((col, idx) => { ligne[col] = valeurs[idx] ?? ''; });\n    ligne._ligne_numero = i + 1;\n    lignes_valides.push(ligne);\n  }\n\n  return [{ json: { statut: 'structure_ok', lignes_valides, lignes_rejetees } }];\n}\n\n// Cas 2 : diagnostic différencié\nconst recuesSet = new Set(colonnesRecues);\nconst attenduesSet = new Set(COLONNES_ATTENDUES);\n\nconst manquantes = COLONNES_ATTENDUES.filter(c => !recuesSet.has(c));\nconst enTrop     = colonnesRecues.filter(c => !attenduesSet.has(c));\n\nlet message;\n\nif (manquantes.length > 0 && enTrop.length === 0) {\n  message = `Colonnes manquantes : ${manquantes.join(', ')}`;\n\n} else if (enTrop.length > 0 && manquantes.length === 0) {\n  message = `Colonnes inattendues : ${enTrop.join(', ')}`;\n\n} else if (manquantes.length > 0 && enTrop.length > 0) {\n  const probableFautes = enTrop.map(recu => {\n    const candidat = manquantes.find(att =>\n      att.startsWith(recu.substring(0, 4)) || recu.startsWith(att.substring(0, 4))\n    );\n    return candidat\n      ? `\"${recu}\" (attendu : \"${candidat}\")`\n      : `\"${recu}\" (inattendue)`;\n  });\n  message = `Colonnes mal orthographiées ou inattendues : ${probableFautes.join(', ')}`;\n\n} else {\n  message = `Ordre des colonnes incorrect. Attendu : ${COLONNES_ATTENDUES.join(', ')} — Reçu : ${colonnesRecues.join(', ')}`;\n}\n\nreturn [{ json: { statut: 'erreur_structure', erreur_structure: message } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        208,
        0
      ],
      "id": "f249ee0c-9fdc-4003-97ad-715dd5495894",
      "name": "Code — Parse CSV"
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nif (input.statut === 'erreur_structure') {\n  return [{ json: input }];\n}\n\nconst modesAutorises = ['driving', 'transit', 'bicycling', 'walking'];\nconst lignesValides = [];\nconst lignesRejetees = [];\n\nfor (const ligne of input.lignes_valides) {   // était : input.lignes\n  const erreurs = [];\n  const id = ligne.id_salarie ? ligne.id_salarie.trim() : null;\n  if (!id) erreurs.push('id_salarie vide');\n  if (!ligne.adresse_domicile) erreurs.push('adresse_domicile vide');\n  if (!ligne.mode_transport || !modesAutorises.includes(ligne.mode_transport)) {\n    erreurs.push(`mode_transport invalide : \"${ligne.mode_transport}\"`);\n  }\n  if (ligne.score_competence === null || isNaN(ligne.score_competence) ||\n      ligne.score_competence < 1 || ligne.score_competence > 5) {\n    erreurs.push(`score_competence invalide : \"${ligne.score_competence}\"`);\n  }\n  if (erreurs.length === 0) {\n    lignesValides.push({ ...ligne, id_salarie: id });\n  } else {\n    lignesRejetees.push({ ...ligne, id_salarie: id, erreurs });\n  }\n}\n\nreturn [{ json: {\n  statut: 'validation_ok',\n  lignes_valides: lignesValides,\n  lignes_rejetees: lignesRejetees\n}}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        416,
