        "jsCode": "const ids_existants = $json.ids_existants || {};\nconst id_salarie = $json.id_salarie;\nconst record_id = ids_existants[id_salarie];\n\nif (record_id) {\n  return [{ json: { ...$json, id: record_id, found: true } }];\n} else {\n  return [{ json: { ...$json, id: null, found: false } }];\n}"
