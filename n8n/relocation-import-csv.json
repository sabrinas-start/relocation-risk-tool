      ],
      "id": "919a5d5e-0dba-485f-9c64-b65ce7b40891",
      "name": "Webhook — Import CSV",
      "webhookId": "837f5906-70e2-4c8f-b682-ded3b788f354"
    },
    {
      "parameters": {
        "jsCode": "const csvString = $input.first().json.body.csv;\nconst lines = csvString.trim().split('\\n');\nconst expectedHeaders = ['id_salarie', 'adresse_domicile', 'mode_transport', 'score_competence'];\n\n// Parser CSV qui gère les guillemets\nfunction parseCSVLine(line) {\n  const values = [];\n  let current = '';\n  let inQuotes = false;\n  for (let i = 0; i < line.length; i++) {\n    const char = line[i];\n    if (char === '\"') {\n      inQuotes = !inQuotes;\n    } else if (char === ',' && !inQuotes) {\n      values.push(current.trim());\n      current = '';\n    } else {\n      current += char;\n    }\n  }\n  values.push(current.trim());\n  return values;\n}\n\nconst headers = parseCSVLine(lines[0]);\nconst headersValid = expectedHeaders.every((h, i) => headers[i] === h) && headers.length === 4;\n\nif (!headersValid) {\n  return [{ json: {\n    statut: 'erreur_structure',\n    message: 'Colonnes invalides ou manquantes. Colonnes attendues : id_salarie, adresse_domicile, mode_transport, score_competence',\n    lignes: []\n  }}];\n}\n\nconst lignes = lines.slice(1).map((line, index) => {\n  const values = parseCSVLine(line);\n  return {\n    ligne_numero: index + 2,\n    id_salarie: values[0] || null,\n    adresse_domicile: values[1] || null,\n    mode_transport: values[2] || null,\n    score_competence: values[3] ? Number(values[3]) : null\n  };\n});\n\nreturn [{ json: { statut: 'structure_ok', headers, lignes }}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        208,
        0
      ],
      "id": "f249ee0c-9fdc-4003-97ad-715dd5495894",
      "name": "Code — Parse CSV"
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\n// Si structure invalide, on propage l'erreur directement\nif (input.statut === 'erreur_structure') {\n  return [{ json: input }];\n}\n\nconst modesAutorises = ['driving', 'transit', 'bicycling', 'walking'];\nconst lignesValides = [];\nconst lignesRejetees = [];\n\nfor (const ligne of input.lignes) {\n  const erreurs = [];\n\n  if (!ligne.id_salarie) erreurs.push('id_salarie vide');\n  if (!ligne.adresse_domicile) erreurs.push('adresse_domicile vide');\n  if (!ligne.mode_transport || !modesAutorises.includes(ligne.mode_transport)) {\n    erreurs.push(`mode_transport invalide : \"${ligne.mode_transport}\"`);\n  }\n  if (ligne.score_competence === null || isNaN(ligne.score_competence) ||\n      ligne.score_competence < 1 || ligne.score_competence > 5) {\n    erreurs.push(`score_competence invalide : \"${ligne.score_competence}\"`);\n  }\n\n  if (erreurs.length === 0) {\n    lignesValides.push(ligne);\n  } else {\n    lignesRejetees.push({ ...ligne, erreurs });\n  }\n}\n\nreturn [{ json: {\n  statut: 'validation_ok',\n  lignes_valides: lignesValides,\n  lignes_rejetees: lignesRejetees\n}}];"
      },
